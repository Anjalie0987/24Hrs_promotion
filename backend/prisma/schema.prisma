// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  BUSINESS_OWNER
}

model User {
  id         String     @id @default(uuid())
  email      String     @unique
  password   String
  firstName  String?
  lastName   String?
  role       Role       @default(USER)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  business   Business?
}

model Business {
  id          String   @id @default(uuid())
  name        String
  category    String
  description String?
  location    String?
  instagram   String?
  whatsapp    String?
  logoUrl     String?
  bannerUrl   String?
  trustScore  Int      @default(50)

  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])

  banners    Banner[]

  sentRequests     PromotionRequest[] @relation("Sender")
  receivedRequests PromotionRequest[] @relation("Receiver")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Promotion {
  id            String   @id @default(uuid())

  requestId     String   @unique
  request       PromotionRequest @relation(fields: [requestId], references: [id])

  startTime     DateTime
  endTime       DateTime

  status        String   @default("ACTIVE") // ACTIVE, COMPLETED, EXPIRED

  senderProof   String?
  receiverProof String?

  createdAt     DateTime @default(now())
}

model PromotionRequest {
  id                  String   @id @default(uuid())
  senderBusinessId    String
  receiverBusinessId  String
  bannerId            String
  status              String   @default("PENDING")
  createdAt           DateTime @default(now())

  senderBusiness      Business @relation("Sender", fields: [senderBusinessId], references: [id])
  receiverBusiness    Business @relation("Receiver", fields: [receiverBusinessId], references: [id])
  banner              Banner   @relation(fields: [bannerId], references: [id])
  
  promotion           Promotion?
}

model Banner {
  id         String   @id @default(uuid())
  imageUrl   String
  title      String?

  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  promotionRequests PromotionRequest[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
